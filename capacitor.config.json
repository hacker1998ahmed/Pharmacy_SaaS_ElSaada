{
  "appId": "com.elsaada.pharmacy",
  "appName": "ElSaada Pharmacy",
  "webDir": "public",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "Camera": {
      "permissions": ["camera"]
    },
    "BarcodeScanner": {
      "permissions": ["camera"]
    }
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": true
  }
}
